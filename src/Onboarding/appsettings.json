{
  "DynamoDb": {
    "TableName": "Onboarding",
    "ServiceUrl": "http://localhost:8000",
    "Region": "us-east-1",
    "AccessKey": "local",
    "SecretKey": "local"
  },
  "Redis": {
    "ConnectionString": "localhost:6379"
  },
  "S3": {
    "BucketName": "onboarding-documents",
    "ServiceUrl": "http://localhost:4566",
    "Region": "us-east-1",
    "AccessKey": "local",
    "SecretKey": "local"
  },
  "Kafka": {
    "BootstrapServers": "localhost:9092",
    "ClientId": "onboarding-api"
  },
  "Outbox": {
    "BatchSize": 25,
    "PollingIntervalSeconds": 2
  },
  "OpenTelemetry": {
    "OtlpEndpoint": "http://localhost:4317"
  },
  "DocumentRules": [
    {
      "segment": "Acquiring",
      "personType": "LegalPerson",
      "requiredDocuments": [ "CnpjCard", "ArticlesOfAssociation", "LegalRepresentativeDocument", "BankAccountProof", "AddressProof" ]
    },
    {
      "segment": "SubAcquiring",
      "personType": "LegalPerson",
      "requiredDocuments": [ "CnpjCard", "ArticlesOfAssociation", "LegalRepresentativeDocument", "BankAccountProof", "BalanceSheet" ]
    },
    {
      "segment": "PayFac",
      "personType": "LegalPerson",
      "requiredDocuments": [ "CnpjCard", "ArticlesOfAssociation", "LegalRepresentativeDocument", "BankAccountProof" ]
    },
    {
      "segment": "Banking",
      "personType": "LegalPerson",
      "requiredDocuments": [ "CnpjCard", "ArticlesOfAssociation", "LegalRepresentativeDocument", "BankAccountProof", "BalanceSheet", "RevenueDeclaration" ]
    }
  ],
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning"
      }
    }
  },
  "AllowedHosts": "*"
}
